<Window
    x:Class="Playground.Views.TestWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Playground.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="using:Playground.Views"
    Title="TestWindow"
    d:DesignHeight="450"
    d:DesignWidth="800"
    ExtendClientAreaToDecorationsHint="true"
    WindowDecorations="BorderOnly"
    mc:Ignorable="d">
    <StackPanel>
        <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
            <Button Click="Button_Click">min</Button>
            <Button Click="Close_Click">close</Button>
        </StackPanel>
        <controls:NoReloadTabControl>
            <TabItem Header="PageA">
                <views:ViewA />
            </TabItem>
            <TabItem Header="PageB">
                <views:ViewB />
            </TabItem>
        </controls:NoReloadTabControl>
    </StackPanel>
</Window>
